<?php
/**
 * News Details Page - Trang chi tiết tin tức
 */
ini_set('display_errors', 1); error_reporting(E_ALL);
// 1. Khởi tạo View an toàn & ServiceManager
require_once __DIR__ . '/../../../core/view_init.php';

// Load required models
require_once __DIR__ . '/../../models/NewsModel.php';
require_once __DIR__ . '/../../models/CategoriesModel.php';

// 2. Chọn service phù hợp
$service = isset($currentService) ? $currentService : ($publicService ?? null);

// Get news ID from URL
$newsId = (int) ($_GET['id'] ?? 0);

// Initialize data variables
$news = null;
$relatedNews = [];
$prevNews = null;
$nextNews = null;
$showErrorMessage = false;
$errorMessage = '';

try {
    if ($newsId <= 0) {
        throw new Exception('ID tin tức không hợp lệ');
    }
    
    // Get news data
    $newsModel = new NewsModel();
    $news = $newsModel->find($newsId);
    
    if (!$news || $news['status'] !== 'published') {
        throw new Exception('Không tìm thấy tin tức');
    }
    
    // Update view count
    $currentViews = (int)($news['views'] ?? 0);
    $newsModel->update($newsId, ['views' => $currentViews + 1]);
    
    // Get category name
    if (!empty($news['category_id'])) {
        $categoriesModel = new CategoriesModel();
        $category = $categoriesModel->find($news['category_id']);
        $news['category_name'] = $category['name'] ?? 'Thương mại XB';
    } else {
        $news['category_name'] = 'Thương mại XB';
    }
    
    // Parse tags
    $news['tags_array'] = !empty($news['tags']) ? array_map('trim', explode(',', $news['tags'])) : [];
    
    // Get related news (same tags, exclude current)
    $allNews = $newsModel->all();
    $relatedNews = [];
    
    if (!empty($news['tags_array'])) {
        // Find news with matching tags
        $relatedWithScore = [];
        
        foreach ($allNews as $item) {
            if ($item['id'] != $newsId && $item['status'] === 'published' && !empty($item['tags'])) {
                $itemTags = array_map('trim', explode(',', $item['tags']));
                
                // Count matching tags
                $matchingTags = array_intersect($news['tags_array'], $itemTags);
                $matchCount = count($matchingTags);
                
                if ($matchCount > 0) {
                    // Get category name for related item
                    if (!empty($item['category_id'])) {
                        $cat = $categoriesModel->find($item['category_id']);
                        $item['category_name'] = $cat['name'] ?? 'Tin tức';
                    } else {
                        $item['category_name'] = 'Tin tức';
                    }
                    
                    $relatedWithScore[] = [
                        'news' => $item,
                        'score' => $matchCount
                    ];
                }
            }
        }
        
        // Sort by matching score (most matching tags first)
        usort($relatedWithScore, function($a, $b) {
            if ($b['score'] === $a['score']) {
                // If same score, sort by date
                $dateA = strtotime($a['news']['published_at'] ?? $a['news']['created_at']);
                $dateB = strtotime($b['news']['published_at'] ?? $b['news']['created_at']);
                return $dateB - $dateA;
            }
            return $b['score'] - $a['score'];
        });
        
        // Get top related news
        foreach ($relatedWithScore as $item) {
            $relatedNews[] = $item['news'];
            if (count($relatedNews) >= 6) break; // Show up to 6 related news
        }
    }
    
    // If no related news by tags, fallback to same category
    if (empty($relatedNews)) {
        foreach ($allNews as $item) {
            if ($item['id'] != $newsId && 
                $item['status'] === 'published' && 
                $item['category_id'] == $news['category_id']) {
                // Get category name for related item
                if (!empty($item['category_id'])) {
                    $cat = $categoriesModel->find($item['category_id']);
                    $item['category_name'] = $cat['name'] ?? 'Tin tức';
                } else {
                    $item['category_name'] = 'Tin tức';
                }
                $relatedNews[] = $item;
                if (count($relatedNews) >= 6) break;
            }
        }
    }
    
    // Get previous and next news
    $publishedNews = array_filter($allNews, function($item) {
        return $item['status'] === 'published';
    });
    
    // Sort by published_at
    usort($publishedNews, function($a, $b) {
        return strtotime($b['published_at'] ?? $b['created_at']) - strtotime($a['published_at'] ?? $a['created_at']);
    });
    
    // Find current news index
    $currentIndex = -1;
    foreach ($publishedNews as $index => $item) {
        if ($item['id'] == $newsId) {
            $currentIndex = $index;
            break;
        }
    }
    
    // Get prev and next
    if ($currentIndex > 0) {
        $prevNews = $publishedNews[$currentIndex - 1];
    }
    if ($currentIndex < count($publishedNews) - 1) {
        $nextNews = $publishedNews[$currentIndex + 1];
    }
    
} catch (Exception $e) {
    error_log("News details error: " . $e->getMessage());
    $showErrorMessage = true;
    $errorMessage = $e->getMessage();
}

// Helper functions
if (!function_exists('getNewsImage')) {
    function getNewsImage($news) {
        if (!empty($news['image'])) {
            if (strpos($news['image'], '/') === 0) {
                return $news['image'];
            }
            if (strpos($news['image'], 'http') === 0) {
                return $news['image'];
            }
            return '/assets/images/' . $news['image'];
        }
        return '/assets/images/about/about_tt&tt_2.jpg';
    }
}

if (!function_exists('formatNewsDate')) {
    function formatNewsDate($date) {
        $timestamp = strtotime($date);
        return date('d/m/Y', $timestamp);
    }
}

if (!function_exists('truncateText')) {
    function truncateText($text, $length = 100) {
        if (strlen($text) <= $length) {
            return $text;
        }
        return substr($text, 0, $length) . '...';
    }
}
